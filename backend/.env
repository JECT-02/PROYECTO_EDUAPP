# =======================================
# EduApp - Configuracion del Backend
# =======================================
# Edita este archivo y coloca tu API key de Gemini

# === Google Gemini (Google AI Studio) ===
# Obten tu API key gratuita en: https://aistudio.google.com/apikey
# Solo necesitas la API key (AIzaSy...), no requiere Project ID
GEMINI_API_KEY=AIzaSyXXXXXXXXXX

# === Base de Datos ===
DATABASE_URL=sqlite+aiosqlite:///./eduapp.db

# === Seguridad ===
SECRET_KEY=default_unsafe_secret_key_change_in_production

# === Frontend (CORS) ===
FRONTEND_URL=http://localhost:5173

# === SMTP (opcional) ===
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=