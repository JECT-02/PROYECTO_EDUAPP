# =======================================
# EduApp - Configuracion del Backend
# =======================================
# Copia este archivo como .env y completa los valores
# Luego edita .env y coloca tu API key de Gemini

# === Google Gemini (Google AI Studio) ===
# Obten tu API key gratuita en: https://aistudio.google.com/apikey
# Solo necesitas la API key (AIzaSy...), no requiere Project ID
GEMINI_API_KEY=AIzaSyXXXXXXXXXX

# === Base de Datos (PostgreSQL) ===
# Formato: postgresql+asyncpg://usuario:password@host:puerto/nombre_bd
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/eduapp

# === Seguridad ===
SECRET_KEY=eduapp_secret_key_change_in_production

# === Frontend (CORS) ===
FRONTEND_URL=http://localhost:5173

