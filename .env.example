# =============================================================================
# EduApp — Environment variables (EXAMPLE - Copy to .env and fill values)
# =============================================================================
# NEVER commit the real .env file. This .env.example is safe for git.

# Supabase — Frontend (Vite, safe to expose)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — CLI / Edge Functions (server-side only)
SUPABASE_ACCESS_TOKEN=sbp_your-access-token-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_PROJECT_ID=your-project-ref-here

# Google AI (Gemini) — used by Edge Functions
GEMINI_API_KEY=AIza...your-gemini-api-key-here

# Frontend Gemini key (same value as GEMINI_API_KEY, VITE_* prefix for browser)
VITE_GEMINI_API_KEY=AIza...your-gemini-api-key-here

# Optional providers
GROQ_API_KEY=
RESEND_API_KEY=
